{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "stager": {
      "description": "Analyzes unstaged changes, stages them, and hands off to the committer.",
      "mode": "subagent",
      "model": "github-copilot/gpt-4o",
      "prompt": "{file:./prompts/stager.md}",
      "tools": {
        "write": false,
        "edit": false,
        "bash": true
      }
    },
    "committer": {
      "description": "Analyzes staged git changes, commits them, and loops back to the stager.",
      "mode": "subagent",
      "model": "github-copilot/gpt-4o",
      "prompt": "{file:./prompts/committer.md}",
      "tools": {
        "write": false,
        "edit": false,
        "bash": true
      }
    }
  },
  "compaction": {
    "auto": false
  },
  "plugin": [
    "opencode-gemini-auth",
    "opencode-swarm",
    "@tarquinen/opencode-dcp@latest",
  ],
  "permission": {
    "codesearch": "allow",
    "lsp": "allow",
    "webfetch": "allow",
    "websearch": "allow"
  },
  "share": "disabled"
}
