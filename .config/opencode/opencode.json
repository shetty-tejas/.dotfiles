{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "stager": {
      "description": "Analyzes unstaged changes, stages them, and hands off to the committer.",
      "mode": "subagent",
      "model": "opencode-go/qwen3.6-plus",
      "prompt": "{file:./prompts/stager.md}",
      "tools": {
        "write": false,
        "edit": false,
        "bash": true
      }
    },
    "committer": {
      "description": "Analyzes staged git changes, commits them, and loops back to the stager.",
      "mode": "subagent",
      "model": "opencode-go/qwen3.5-plus",
      "prompt": "{file:./prompts/committer.md}",
      "tools": {
        "write": false,
        "edit": false,
        "bash": true
      }
    }
  },
  "plugin": [
    "opencode-gemini-auth",
    "opencode-swarm"
  ],
}
